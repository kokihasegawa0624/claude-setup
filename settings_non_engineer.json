{
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(npm start)",
      "Bash(npm run dev)",
      "Bash(npm run build)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(del:*)",
      "Bash(rmdir:*)",
      "Bash(Remove-Item:*)",
      "Bash(format:*)",
      "Bash(shutdown:*)",
      "Bash(taskkill:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git add -f:*)",
      "Bash(git add --force:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(Invoke-WebRequest:*)",
      "Bash(npm install -g:*)",
      "Bash(pip install:*)",
      "Read(.env*)",
      "Read(*secret*)",
      "Read(*credential*)",
      "Read(*token*)"
    ]
  }
}
