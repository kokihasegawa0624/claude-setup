{
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(move:*)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(npm start)",
      "Bash(npm run dev)",
      "Bash(npm run build)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(del:*)",
      "Bash(rmdir:*)",
      "Bash(Remove-Item:*)",
      "Bash(format:*)",
      "Bash(shutdown:*)",
      "Bash(taskkill:*)"
    ]
  }
}
